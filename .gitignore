# --- Jupyter Notebooks ---
.ipynb_checkpoints/
# This hides the 'autosave' folders Jupyter creates

# --- Python Environment & Cache ---
__pycache__/
*.py[cod]
.venv/
venv/
# This ignores the 'node_modules' equivalent of Python

# --- Data Management ---
# We ignore all CSVs to prevent massive price history files from bloating the repo
*.csv
# But we EXEMPT 'the source-of-truth file' 
!asx200.csv

# --- Local Settings & Secrets ---
.env
.vscode/
.DS_Store
